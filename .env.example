ENVIRONMENT=local
DATABASE_URL=sqlite:///./data/astra_nexus.sqlite3
DATA_DIR=./data
WORKSPACE_BASE_PATH=./data/workspaces
BRAIN_PROVIDER=dummy
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
TEAM_MAX_REVISION_LOOPS=1
TEAM_ATTACHMENT_MAX_EXTRACTED_CHARS=50000
TEAM_ATTACHMENT_MAX_PROMPT_CHARS=20000
TEAM_ATTACHMENT_PDF_MAX_PAGES=30
TEAM_ATTACHMENT_DOCX_INCLUDE_TABLES=true

NODRIVER_USER_DATA_DIR=./data/browser_profiles/default
NODRIVER_HEADLESS=false
NODRIVER_WINDOW_MODE=small
NODRIVER_WINDOW_WIDTH=1100
NODRIVER_WINDOW_HEIGHT=800
NODRIVER_WINDOW_X=20
NODRIVER_WINDOW_Y=20
NODRIVER_BACKGROUND_START=true
NODRIVER_DISABLE_FOCUS_STEALING=true
NODRIVER_START_TIMEOUT_SECONDS=90
NODRIVER_START_RETRIES=3
NODRIVER_START_RETRY_DELAY_SECONDS=2
NODRIVER_AFTER_TERMINATE_GRACE_SECONDS=2
NODRIVER_NO_SANDBOX=false
NODRIVER_BROWSER_EXECUTABLE_PATH=
NODRIVER_CHATGPT_URL=https://chatgpt.com/
NODRIVER_RESPONSE_TIMEOUT_SECONDS=180
NODRIVER_PAGE_LOAD_TIMEOUT_SECONDS=60
NODRIVER_KEEP_BROWSER_OPEN_ON_ERROR=false
NODRIVER_AGENT_MODE=single_profile
NODRIVER_DEBUG_SCREENSHOTS=false
NODRIVER_SCREENSHOTS_DIR=./data/debug/screenshots

# Не коммитить реальный токен. Если переменная пустая, Telegram bot не запускается.
TELEGRAM_BOT_TOKEN=
TEAM_TELEGRAM_PROVIDER=fake
TEAM_TELEGRAM_ALLOWED_CHAT_IDS=
TEAM_TELEGRAM_LOG_CHAT_ID=
TEAM_TELEGRAM_DOWNLOADS_DIR=./data/team_telegram_downloads
TEAM_TELEGRAM_SEND_TYPING=true
TEAM_TELEGRAM_MAX_FILE_SIZE_MB=10
TEAM_TELEGRAM_HUMAN_MESSAGES=true
TEAM_ATMOSPHERE_ENABLED=true
TEAM_ATMOSPHERE_LEVEL=normal
TEAM_ATMOSPHERE_SEND_DELAYS=false
TEAM_ATMOSPHERE_MIN_DELAY_SECONDS=0.3
TEAM_ATMOSPHERE_MAX_DELAY_SECONDS=1.4
TEAM_ATMOSPHERE_EMOJI_ENABLED=false
TEAM_ATMOSPHERE_MAX_MAIN_MESSAGES_PER_RUN=20
TEAM_ATMOSPHERE_SUPPRESS_TECHNICAL_IN_MAIN=true
